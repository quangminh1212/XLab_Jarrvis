# =============================================
# MCP Voice Bridge - Environment Configuration
# =============================================
# Copy this file to .env and adjust as needed

# Python executable path (default: python)
# On some systems it might be python3
# VOICE_PYTHON=python

# Default language for STT and TTS (BCP-47 format)
# vi-VN = Vietnamese, en-US = English, ja-JP = Japanese
VOICE_LANGUAGE=vi-VN

# Microphone device index (-1 = system default)
# Run: npm run test:devices  to see available devices
# VOICE_MIC_INDEX=-1

# TTS voice override (edge-tts voice name)
# List voices: edge-tts --list-voices
# VOICE_TTS_VOICE=vi-VN-HoaiMyNeural
